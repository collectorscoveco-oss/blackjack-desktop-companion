{
  "name": "blackjack-overlay",
  "version": "2.0.3",
  "private": true,
  "description": "Electron desktop blackjack overlay with manual basic strategy assistant.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test tests/*.test.mjs",
    "dist": "electron-builder --win nsis",
    "dist:win": "electron-builder --win nsis"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ai.openclaw.blackjackoverlay",
    "productName": "Blackjack Overlay",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "collectorscoveco-oss",
        "repo": "blackjack-desktop-companion"
      }
    ],
    "files": [
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blackjack Overlay"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
