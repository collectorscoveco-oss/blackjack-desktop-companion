// Reference schema for future Prisma/Supabase migration.
// Current MVP persists to local JSON for speed and zero-setup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Driver {
  id           String        @id @default(cuid())
  name         String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id             String   @id @default(cuid())
  businessDate   String
  orderNumber    String
  orderTotal     Float
  assumedBill    Float
  giveDriver     Float
  customerPaid   Float
  backToRegister Float
  driverTip      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  driverId       String
  driver         Driver   @relation(fields: [driverId], references: [id])
}

model DailySummary {
  businessDate         String   @id
  totalTransactions    Int
  totalGiveDriver      Float
  totalBackToRegister  Float
  totalDriverTips      Float
  updatedAt            DateTime @updatedAt
}
